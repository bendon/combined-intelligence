# ── Application ───────────────────────────────────────────────────────────────
BASE_URL=https://combinedintelligence.us
COOKIE_DOMAIN=combinedintelligence.us
COOKIE_SECURE=true

# ── Google OAuth2 ─────────────────────────────────────────────────────────────
# Create at console.cloud.google.com > APIs & Services > Credentials
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=https://combinedintelligence.us/api/auth/google/callback

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-64-char-random-hex
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_USER=ci_admin
MONGO_PASSWORD=change-me
MONGO_DB=combined_intelligence
MONGO_URL=mongodb://ci_admin:change-me@mongo:27017/combined_intelligence?authSource=admin

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=change-me
REDIS_URL=redis://:change-me@redis:6379/0

# ── Qdrant ────────────────────────────────────────────────────────────────────
QDRANT_URL=http://qdrant:6333

# ── Scaleway S3 ───────────────────────────────────────────────────────────────
# Create bucket in Scaleway console > Object Storage (nl-ams region)
S3_ENDPOINT_URL=https://s3.nl-ams.scw.cloud
S3_ACCESS_KEY=your-scaleway-access-key
S3_SECRET_KEY=your-scaleway-secret-key
S3_BUCKET=combined-intelligence-assets

# ── GCP (for Ollama VM) ───────────────────────────────────────────────────────
# Service account JSON path (mounted as volume in docker-compose)
GCP_PROJECT=your-gcp-project-id
GCP_ZONE=us-central1-a
GCP_VM_INSTANCE=ci-ollama-inference
GOOGLE_APPLICATION_CREDENTIALS=/app/gcp/service-account.json

# ── Ollama ────────────────────────────────────────────────────────────────────
# Internal IP of the GCP VM (set after VM is created)
OLLAMA_BASE_URL=http://10.128.0.x:11434
OLLAMA_MODEL=deepseek-r1:8b

# ── VAPID (Web Push) ──────────────────────────────────────────────────────────
# Generate: python -c "from py_vapid import Vapid; v = Vapid(); v.generate_keys(); print(v.private_key.decode(), v.public_key.decode())"
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_CLAIMS_SUB=mailto:desk@combinedintelligence.us

# ── External LLM APIs (optional) ─────────────────────────────────────────────
# Used for document classification and enrichment. Leave blank to skip.
# Anthropic: get key at console.anthropic.com
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# OpenAI: get key at platform.openai.com
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── Flower ────────────────────────────────────────────────────────────────────
FLOWER_USER=admin
FLOWER_PASSWORD=change-me
