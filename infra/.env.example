# ── Application ───────────────────────────────────────────────────────────────
BASE_URL=https://combinedintelligence.us
COOKIE_DOMAIN=combinedintelligence.us
COOKIE_SECURE=true

# ── Google OAuth2 ─────────────────────────────────────────────────────────────
# Create at console.cloud.google.com > APIs & Services > Credentials
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=https://combinedintelligence.us/api/auth/google/callback

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-64-char-random-hex
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_USER=ci_admin
MONGO_PASSWORD=change-me
MONGO_DB=combined_intelligence
MONGO_URL=mongodb://ci_admin:change-me@mongo:27017/combined_intelligence?authSource=admin

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=change-me
REDIS_URL=redis://:change-me@redis:6379/0

# ── Qdrant ────────────────────────────────────────────────────────────────────
QDRANT_URL=http://qdrant:6333

# ── Scaleway S3 ───────────────────────────────────────────────────────────────
# Create bucket in Scaleway console > Object Storage (nl-ams region)
S3_ENDPOINT_URL=https://s3.nl-ams.scw.cloud
S3_ACCESS_KEY=your-scaleway-access-key
S3_SECRET_KEY=your-scaleway-secret-key
S3_BUCKET=combined-intelligence-assets

# ── GCP (for Ollama VM) ───────────────────────────────────────────────────────
# Service account JSON path (mounted as volume in docker-compose)
GCP_PROJECT=your-gcp-project-id
GCP_ZONE=us-central1-a
GCP_VM_INSTANCE=ci-ollama-inference
GOOGLE_APPLICATION_CREDENTIALS=/app/gcp/service-account.json

# ── GCP Cloud TPU (Spot TPU VM) ───────────────────────────────────────────────
# Used by infra/gcp/tpu-spot-create.sh and tpu-rest-*.ps1 (when infra/.env is loaded).
# Pick zone + accelerator + runtime together — always confirm with:
#   .\tpu-rest-list-accelerator-types.ps1 -Zone <your-zone>
#   .\tpu-rest-list-runtime-versions.ps1   -Zone <your-zone>
TPU_PROJECT=your-gcp-project-id
# Default primary: Singapore (asia-southeast1-b) v6e-1 Spot — best Spot v6e rate
# of the Asia zones allocated to this project, and the same zone has v5e too.
# Use .\tpu-rest-survey-zones.ps1 -ZonePattern "asia-*" to (re)check exposure.
TPU_ZONE=asia-southeast1-b
TPU_NAME=ci-tpu-spot
# v6e (Trillium, PyTorch/JAX): v2-alpha-tpuv6e — see https://cloud.google.com/tpu/docs/runtimes
TPU_ACCELERATOR_TYPE=v6e-1
TPU_RUNTIME_VERSION=v2-alpha-tpuv6e

# Failover candidates for tpu-rest-watchdog.ps1.
# Format: semicolon-separated list of "zone|accelerator|runtime" triples.
# The watchdog tries the primary first, then rotates through this list on
# Spot preemption or "no capacity" create failures. Set to empty to disable.
# Example: cheap v5e in Iowa → v6e in US-East-5 → Mumbai v6e fallback.
TPU_FAILOVERS=us-central1-a|v5litepod-1|v2-alpha-tpuv5-lite;us-east5-c|v6e-1|v2-alpha-tpuv6e;asia-south1-b|v6e-1|v2-alpha-tpuv6e
# Set true so workers get public IPs (simple apt/curl/pip to internet AND
# so the Ubuntu backend can reach JetStream directly). If you turn this off
# you need a Cloud NAT for egress AND an internal LB / IAP tunnel for the
# backend to reach the TPU - see infra/gcp/tpu-vm/README.md.
TPU_ENABLE_EXTERNAL_IPS=true
# tpu-spot-create.sh (gcloud) only: set true to force internal-only.
TPU_INTERNAL_IPS_ONLY=false

# ── TPU workload deployment ─────────────────────────────────────────────────
# Everything below tells the TPU VM what to install + run after boot. The
# Python control plane reads infra/gcp/tpu-vm/bootstrap.sh, embeds it in the
# node's `metadata.startup-script`, and the bundled systemd unit launches
# JetStream once the bootstrap finishes. See infra/gcp/tpu-vm/README.md for
# the full deployment story.

# Path (absolute, or relative to repo root) of the startup script. Leave
# empty to use the default infra/gcp/tpu-vm/bootstrap.sh if it exists. Set
# to "" (empty) on the same line to skip workload install entirely - useful
# when you want a bare TPU for ad-hoc JAX REPL work.
TPU_STARTUP_SCRIPT_PATH=

# Required for the canonical bootstrap.sh: where to fetch model weights from.
# Format: "KEY=value;KEY=value" - parsed by app.tpu.config.
# Replace gs://your-bucket/maxtext-gemma2-9b with your MaxText checkpoint dir.
TPU_WORKLOAD_METADATA=MODEL_NAME=gemma2-9b;MODEL_GCS=gs://your-bucket/maxtext-gemma2-9b

# Service account the TPU VM impersonates. Needs roles/storage.objectViewer
# on the bucket above (for the gsutil cp in bootstrap.sh). Leave empty to
# use the project default compute SA - works but is over-privileged.
TPU_WORKLOAD_SERVICE_ACCOUNT=

# GCE network tag(s) applied to the TPU node. The firewall rule that lets
# the Ubuntu server reach port 9000 should target this tag.
TPU_NETWORK_TAGS=ci-tpu

# Port that JetStream listens on inside the TPU VM. The backend constructs
# http://<external-ip>:$JETSTREAM_PORT to send prompts. Default 9000.
JETSTREAM_PORT=9000

# Static public IPv4 of the **app host** (e.g. Azure VM with Standard public IP).
# The ONLY address allowed to reach JetStream on GCP Spot TPUs (tcp:9000).
# Used by infra/gcp/firewall-tpu-setup.sh. Must match the VM’s outbound-facing
# IP when Celery calls the TPU (same machine if API + workers run on that VM).
#
# Example: UBUNTU_STATIC_IP=20.157.90.21
UBUNTU_STATIC_IP=

# (Optional) Additional /32s allowed to SSH into TPUs for ops, comma-separated.
# Empty = SSH not exposed (recommended; use IAP tunnel instead).
TPU_SSH_ALLOWED_IPS=
# OAuth2 bearer token for direct REST calls to tpu.googleapis.com (local dev only).
# Short-lived (~1h). Prefer a service-account key (see below) for unattended runs.
# Put the real value in infra/.env (gitignored), not here — this file is a template.
# On GCE, leave empty: infra/gcp/tpu-rest-*.ps1 reads the token from the metadata server.
GOOGLE_OAUTH_ACCESS_TOKEN=

# Path to a service-account JSON key used by infra/gcp/tpu-rest-*.ps1 to mint
# fresh tokens. The key itself is long-lived (until you rotate it in IAM) so
# this is the recommended option for unattended/cron usage.
# Default: infra/gcp/service-account.json (also git-ignored).
GCP_SERVICE_ACCOUNT_KEY_FILE=
# Optional hook command run inside TPU VM when preemption notice is detected.
# Example: python /srv/train.py --checkpoint-only
PREEMPT_CHECKPOINT_HOOK=

# ── Ollama ────────────────────────────────────────────────────────────────────
# Internal IP of the GCP VM (set after VM is created)
OLLAMA_BASE_URL=http://10.128.0.x:11434
OLLAMA_MODEL=deepseek-r1:8b

# ── VAPID (Web Push) ──────────────────────────────────────────────────────────
# Generate: python -c "from py_vapid import Vapid; v = Vapid(); v.generate_keys(); print(v.private_key.decode(), v.public_key.decode())"
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_CLAIMS_SUB=mailto:desk@combinedintelligence.us

# ── External LLM APIs (optional) ─────────────────────────────────────────────
# Used for document classification and enrichment. Leave blank to skip.
# Anthropic: get key at console.anthropic.com
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# OpenAI: get key at platform.openai.com
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── Flower ────────────────────────────────────────────────────────────────────
FLOWER_USER=admin
FLOWER_PASSWORD=change-me
